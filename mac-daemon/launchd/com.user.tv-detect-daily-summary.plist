<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.user.tv-detect-daily-summary</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/simon/bin/tv-detect-daily-summary.sh</string>
  </array>
  <!-- 08:00 daily — well after the 03:30 retrain; user typically up. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>8</integer>
    <key>Minute</key><integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/Users/simon/Library/Logs/tv-detect-daily.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/simon/Library/Logs/tv-detect-daily.log</string>
</dict>
</plist>
